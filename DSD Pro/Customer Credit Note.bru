meta {
  name: Customer Credit Note
  type: http
  seq: 13
}

post {
  url: 192.168.1.119:8070/web/get_user_credit_not_details
  body: json
  auth: inherit
}

body:json {
  {
      "params": {
          "outstanding": false,
          "page": 0,
          "data": {
              "invoice_id": 1958
          }
      }
  }
}

script:post-response {
  var template = `
  <style type="text/css">
      .tftable {font-size:14px;color:#333333;width:100%;border-width: 1px;border-color: #87ceeb;border-collapse: collapse;}
      .tftable th {font-size:18px;background-color:#87ceeb;border-width: 1px;padding: 8px;border-style: solid;border-color: #87ceeb;text-align:left;}
      .tftable tr {background-color:#ffffff;}
      .tftable td {font-size:14px;border-width: 1px;padding: 8px;border-style: solid;border-color: #87ceeb;}
      .tftable tr:hover {background-color:#e0ffff;}
  </style>
  
  <table class="tftable" border="1">
      <tr>
          <th>Invoice ID</th>
          <th>Invoice Number</th>
          <th>Customer Name</th>
          <th>Invoice Date</th>
          <th>Due Date</th>
          <th>Amount Total</th>
          <th>Amount Untaxed</th>
          <th>State</th>
          <th>Invoice State</th>
      </tr>
      
      {{#each response.result.payload.invoice_details}}
          <tr>
              <td>{{invoice_id}}</td>
              <td>{{invoice_number}}</td>
              <td>{{customer_name}}</td>
              <td>{{invoice_date}}</td>
              <td>{{due_date}}</td>
              <td>{{amount_total}}</td>
              <td>{{amount_untaxed}}</td>
              <td>{{state}}</td>
              <td>{{invoice_state}}</td>
          </tr>
      {{/each}}
  </table>
  `;
  
  function constructVisualizerPayload() {
      var res = res.getBody();
  
      return {response: res};
  }
  
  bru.visualize("html", {
      template: template,
      data: constructVisualizerPayload()
  });
}

